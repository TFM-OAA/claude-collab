{
    "hooks":  {
                  "SessionStart":  [
                                       {
                                           "matcher":  "startup|resume|clear",
                                           "hooks":  [
                                                         {
                                                             "type":  "command",
                                                             "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand "
                                                         }
                                                     ]
                                       }
                                   ],
                  "PreToolUse":  [
                                     {
                                         "matcher":  "Edit|Write|NotebookEdit",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand "
                                                       }
                                                   ]
                                     }
                                 ],
                  "SessionEnd":  [
                                     {
                                         "matcher":  "",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand "
                                                       }
                                                   ]
                                     }
                                 ]
              }
}
